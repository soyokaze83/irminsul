# Irminsul — example environment variables
#
# The examples in crates/wa-client/examples/ are configured via WA_* variables.
# This project does NOT auto-load .env, so copy and source it, e.g.:
#
#   cp .env.example .env && set -a && . ./.env && set +a
#
# Most examples exit before connecting unless their required vars are set, and —
# except live_pairing_code — expect an already-paired session in WA_SESSION_DB.
# Everything below is commented out; uncomment and edit only what you need.

# ── Global ──────────────────────────────────────────────────────────────────
#WA_SESSION_DB=.wa/session.sqlite      # SQLite session/auth DB path (this is the default)
#WA_PHONE_NUMBER=1234567890            # pairing-code request number (live_pairing_code)
#WA_QR_REFERENCE=                      # server-provided pair-device reference for QR payloads

# ── Pairing-code login (live_pairing_code) ──────────────────────────────────
#WA_PAIRING_CODE=ABCD1234              # optional 8-char custom code
#WA_PAIRING_TIMEOUT_SECS=60

# ── Direct messages (live_text) ─────────────────────────────────────────────
#WA_TARGET_JID=1234567890@s.whatsapp.net
#WA_MESSAGE_KIND=text                  # text|contact|location|poll|event|reaction|edit|delete|pin
# contact:
#WA_CONTACT_DISPLAY_NAME=
#WA_CONTACT_VCARD=
# location:
#WA_LOCATION_LATITUDE=
#WA_LOCATION_LONGITUDE=
#WA_LOCATION_NAME=
#WA_LOCATION_ADDRESS=
#WA_LOCATION_URL=
# poll:
#WA_POLL_NAME=
#WA_POLL_OPTIONS=Yes,No
#WA_POLL_SELECTABLE_COUNT=1
#WA_POLL_SECRET_HEX=
# event:
#WA_EVENT_NAME=
#WA_EVENT_DESCRIPTION=
#WA_EVENT_START_UNIX=
#WA_EVENT_END_UNIX=
#WA_EVENT_JOIN_LINK=
#WA_EVENT_SECRET_HEX=
# reaction/edit/delete/pin (each also accepts *_REMOTE_JID, *_FROM_ME, *_PARTICIPANT):
#WA_REACTION_MESSAGE_ID=
#WA_REACTION_TEXT=👍
#WA_EDIT_MESSAGE_ID=
#WA_EDIT_TEXT=
#WA_EDIT_TIMESTAMP_MS=
#WA_DELETE_MESSAGE_ID=
#WA_PIN_MESSAGE_ID=
#WA_PIN_ACTION=
#WA_PIN_TIMESTAMP_MS=

# ── Receiving (live_receive) ────────────────────────────────────────────────
#WA_RECEIVE=1
#WA_RECEIVE_TIMEOUT_SECS=60
#WA_RECEIVE_REMOTE_JID=

# ── Media send (live_media; needs --features http-media) ────────────────────
#WA_MEDIA_PATH=./image.jpg
#WA_MEDIA_KIND=image                   # image|video|gif|ptv|audio|ptt|document|sticker
#WA_MEDIA_MIMETYPE=
#WA_MEDIA_CAPTION=
#WA_MEDIA_VIEW_ONCE=1                  # image/video only
# optional per-kind tuning knobs:
#   WA_MEDIA_{AUDIO,VIDEO,GIF,PTV,PTT}_SECONDS, WA_MEDIA_{VIDEO,GIF,PTV,STICKER}_HEIGHT/_WIDTH,
#   WA_MEDIA_AUDIO_PTT, WA_MEDIA_DOCUMENT_TITLE/_FILE_NAME/_PAGE_COUNT, WA_MEDIA_STICKER_ANIMATED

# ── Media retry (live_media_retry) ──────────────────────────────────────────
#WA_MEDIA_RETRY_REMOTE_JID=
#WA_MEDIA_RETRY_MESSAGE_ID=
#WA_MEDIA_RETRY_MEDIA_KEY_HEX=
#WA_MEDIA_RETRY_FROM_ME=
#WA_MEDIA_RETRY_PARTICIPANT=
# with --features http-media, download the refreshed media:
#WA_MEDIA_RETRY_WAIT_RESPONSE=1
#WA_MEDIA_RETRY_FILE_SHA256_HEX=
#WA_MEDIA_RETRY_FILE_ENC_SHA256_HEX=
#WA_MEDIA_RETRY_FILE_LENGTH=
#WA_MEDIA_RETRY_KIND=
#WA_MEDIA_RETRY_FALLBACK_HOST=
#WA_MEDIA_RETRY_URL=
#WA_MEDIA_RETRY_DIRECT_PATH=
#WA_MEDIA_RETRY_MEDIA_KEY_TIMESTAMP_MS=
#WA_MEDIA_RETRY_TIMEOUT_SECS=

# ── Thumbnail sends (need --features http-media,image) ──────────────────────
#WA_VIDEO_PATH=./video.mp4             # live_video_thumbnail
#WA_VIDEO_THUMBNAIL_FFMPEG=ffmpeg
#WA_VIDEO_THUMBNAIL_SEEK_TIME=
#WA_DOCUMENT_PATH=./document.pdf       # live_document_thumbnail
#WA_DOCUMENT_THUMBNAIL_PDFTOPPM=pdftoppm
#WA_DOCUMENT_THUMBNAIL_PAGE=1
#WA_DOCUMENT_THUMBNAIL_DPI=

# ── Status / broadcast (live_status) ────────────────────────────────────────
#WA_STATUS_JIDS=1234567890@s.whatsapp.net   # comma-separated user JIDs
#WA_STATUS_KIND=text                   # text|image|video|document|audio|sticker|poll|event
#WA_STATUS_TEXT=
# media (image/audio/sticker need http-media; video/document need http-media,image):
#WA_STATUS_MEDIA_PATH=
#WA_STATUS_VIDEO_PATH=
#WA_STATUS_DOCUMENT_PATH=
#WA_STATUS_AUDIO_PATH=
#WA_STATUS_STICKER_PATH=
# metadata + poll/event mirror the live_text vars with a WA_STATUS_ prefix
#   (WA_STATUS_*_MIMETYPE/_CAPTION, WA_STATUS_POLL_*, WA_STATUS_EVENT_*)

# ── History sync (live_history_sync; needs --features http-media) ───────────
#WA_HISTORY_SYNC=1
#WA_HISTORY_SYNC_TIMEOUT_SECS=
#WA_HISTORY_SYNC_FALLBACK_HOST=
#WA_HISTORY_SYNC_LATEST=

# ── App-state chat pin (live_chat_pin) ──────────────────────────────────────
#WA_CHAT_PIN_JID=1234567890@s.whatsapp.net
#WA_APP_STATE_KEY_ID_HEX=
#WA_APP_STATE_KEY_DATA_HEX=            # only if the key isn't already in WA_SESSION_DB
#WA_CHAT_PINNED=                       # false to unpin
#WA_CHAT_PIN_TIMESTAMP_MS=

# ── Groups (live_group / live_group_send) ───────────────────────────────────
#WA_GROUP_JID=1234567890-1234567890@g.us
#WA_GROUP_SEND_JID=1234567890-1234567890@g.us
#WA_GROUP_TEXT=

# ── Communities (live_community) ────────────────────────────────────────────
#WA_COMMUNITY_JID=1234567890-1234567890@g.us
#WA_COMMUNITY_INVITE_CODE=
#WA_COMMUNITY_FETCH_PARTICIPATING=1
#WA_COMMUNITY_FETCH_LINKED_GROUPS=1
#WA_COMMUNITY_RESOLVE_LINKED_GROUPS=1
#WA_COMMUNITY_FETCH_JOIN_REQUESTS=1

# ── Newsletters (live_newsletter) ───────────────────────────────────────────
#WA_NEWSLETTER_JID=1234567890@newsletter
#WA_NEWSLETTER_INVITE=
#WA_NEWSLETTER_FETCH_COUNTS=1
#WA_NEWSLETTER_FETCH_MESSAGES=1
#WA_NEWSLETTER_MESSAGE_COUNT=
#WA_NEWSLETTER_MESSAGE_SINCE=
#WA_NEWSLETTER_MESSAGE_AFTER=
#WA_NEWSLETTER_LIVE_UPDATES=1

# ── Business (live_business_*) ──────────────────────────────────────────────
#WA_BUSINESS_JID=1234567890@s.whatsapp.net   # profile fetch
#WA_BUSINESS_PROFILE_UPDATE=1                # mutates your own business profile
#WA_BUSINESS_PROFILE_ADDRESS=
#WA_BUSINESS_PROFILE_EMAIL=
#WA_BUSINESS_PROFILE_DESCRIPTION=
#WA_BUSINESS_PROFILE_WEBSITES=
#WA_BUSINESS_CATALOG_JID=
#WA_BUSINESS_CATALOG_LIMIT=
#WA_BUSINESS_CATALOG_CURSOR=
#WA_BUSINESS_COLLECTIONS_JID=
#WA_BUSINESS_COLLECTION_LIMIT=
#WA_BUSINESS_COLLECTION_ITEM_LIMIT=
#WA_BUSINESS_ORDER_ID=
#WA_BUSINESS_ORDER_TOKEN=
# media (needs --features http-media):
#WA_BUSINESS_MEDIA_PATH=./image.jpg
#WA_BUSINESS_MEDIA_KIND=product_image        # product_image|cover_photo
#WA_BUSINESS_MEDIA_FALLBACK_HOST=
#WA_BUSINESS_COVER_PHOTO_UPDATE=1            # mutates your own cover photo
#WA_BUSINESS_COVER_PHOTO_PATH=
#WA_BUSINESS_COVER_PHOTO_REMOVE=1
#WA_BUSINESS_COVER_PHOTO_ID=

# ── Profile picture (live_profile_picture; needs --features image) ──────────
#WA_PROFILE_PICTURE_PATH=./profile.jpg
#WA_PROFILE_PICTURE_TARGET_JID=        # omit to update your own
#WA_PROFILE_PICTURE_SIZE=
#WA_PROFILE_PICTURE_PREVIEW_SIZE=
#WA_PROFILE_PICTURE_QUALITY=

# ── Link previews (live_link_preview / live_generated_link_preview;
#    need --features http-media,link-preview,image) ──────────────────────────
#WA_LINK_PREVIEW_URL=https://example.com
#WA_LINK_PREVIEW_TEXT=
#WA_LINK_PREVIEW_IMAGE_PATH=           # drives the generated-thumbnail variant
#WA_LINK_PREVIEW_TITLE=
#WA_LINK_PREVIEW_DESCRIPTION=

# ── Live smoke tests (cargo test -p wa-client --test live_e2e -- --ignored) ──
#WA_LIVE_E2E=1
